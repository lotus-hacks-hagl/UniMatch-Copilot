{
    "swagger": "2.0",
    "info": {
        "description": "Simple AI orchestration service for UniMatch using Exa and TinyFish with heuristic fallback.",
        "title": "UniMatch AI Service API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:9000",
    "basePath": "/",
    "paths": {
        "/jobs/analyze": {
            "post": {
                "description": "Accepts a student profile and candidate universities, then asynchronously sends analyze results back to the backend callback URL.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "jobs"
                ],
                "summary": "Queue analyze job",
                "parameters": [
                    {
                        "description": "Analyze request",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dto.AnalyzeJobRequest"
                        }
                    }
                ],
                "responses": {
                    "202": {
                        "description": "Accepted",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/response.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/dto.JobAcceptedResponse"
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/response.Response"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/response.Response"
                        }
                    }
                }
            }
        },
        "/jobs/crawl": {
            "post": {
                "description": "Accepts a university crawl job and asynchronously posts crawl results to the backend callback URL.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "jobs"
                ],
                "summary": "Queue crawl job",
                "parameters": [
                    {
                        "description": "Crawl request",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dto.CrawlJobRequest"
                        }
                    }
                ],
                "responses": {
                    "202": {
                        "description": "Accepted",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/response.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/dto.JobAcceptedResponse"
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/response.Response"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/response.Response"
                        }
                    }
                }
            }
        },
        "/jobs/report": {
            "post": {
                "description": "Accepts recommendations and asynchronously posts generated report content to the backend callback URL.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "jobs"
                ],
                "summary": "Queue report job",
                "parameters": [
                    {
                        "description": "Report request",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dto.ReportJobRequest"
                        }
                    }
                ],
                "responses": {
                    "202": {
                        "description": "Accepted",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/response.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/dto.JobAcceptedResponse"
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/response.Response"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/response.Response"
                        }
                    }
                }
            }
        },
        "/jobs/{job_id}": {
            "get": {
                "description": "Returns local in-memory debug state for a job. Intended for local or test environments only.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "jobs"
                ],
                "summary": "Get local job debug state",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Job ID",
                        "name": "job_id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/response.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/dto.JobDebugResponse"
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/response.Response"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "dto.AnalyzeInput": {
            "type": "object",
            "properties": {
                "achievements": {
                    "type": "string"
                },
                "budget_usd_per_year": {
                    "type": "integer"
                },
                "candidate_universities": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/dto.CandidateUniversity"
                    }
                },
                "extracurriculars": {
                    "type": "string"
                },
                "full_name": {
                    "type": "string"
                },
                "gpa_normalized": {
                    "type": "number"
                },
                "ielts_overall": {
                    "type": "number"
                },
                "intended_major": {
                    "type": "string"
                },
                "preferred_countries": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "sat_total": {
                    "type": "integer"
                },
                "scholarship_required": {
                    "type": "boolean"
                },
                "target_intake": {
                    "type": "string"
                },
                "toefl_total": {
                    "type": "integer"
                }
            }
        },
        "dto.AnalyzeJobRequest": {
            "type": "object",
            "required": [
                "callback_url",
                "case_id",
                "input",
                "job_id"
            ],
            "properties": {
                "callback_url": {
                    "type": "string"
                },
                "case_id": {
                    "type": "string"
                },
                "input": {
                    "$ref": "#/definitions/dto.AnalyzeInput"
                },
                "job_id": {
                    "type": "string"
                }
            }
        },
        "dto.CandidateUniversity": {
            "type": "object",
            "properties": {
                "acceptance_rate": {
                    "type": "number"
                },
                "available_majors": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "country": {
                    "type": "string"
                },
                "gpa_expectation_normalized": {
                    "type": "number"
                },
                "ielts_min": {
                    "type": "number"
                },
                "qs_rank": {
                    "type": "integer"
                },
                "sat_required": {
                    "type": "boolean"
                },
                "scholarship_available": {
                    "type": "boolean"
                },
                "tuition_usd_per_year": {
                    "type": "integer"
                },
                "university_id": {
                    "type": "string"
                },
                "university_name": {
                    "type": "string"
                }
            }
        },
        "dto.CrawlJobRequest": {
            "type": "object",
            "required": [
                "callback_url",
                "job_id",
                "university_id"
            ],
            "properties": {
                "callback_url": {
                    "type": "string"
                },
                "job_id": {
                    "type": "string"
                },
                "metadata": {
                    "type": "object",
                    "additionalProperties": true
                },
                "university_id": {
                    "type": "string"
                }
            }
        },
        "dto.JobAcceptedResponse": {
            "type": "object",
            "properties": {
                "job_id": {
                    "type": "string"
                },
                "message": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                }
            }
        },
        "dto.JobDebugResponse": {
            "type": "object",
            "properties": {
                "callback_attempts": {
                    "type": "integer"
                },
                "callback_status": {
                    "type": "string"
                },
                "job_id": {
                    "type": "string"
                },
                "job_type": {
                    "type": "string"
                },
                "last_error": {
                    "type": "string"
                },
                "openai_attempts": {
                    "type": "integer"
                },
                "openai_fill_used": {
                    "type": "boolean"
                },
                "search_attempts": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/dto.SearchAttempt"
                    }
                },
                "status": {
                    "type": "string"
                },
                "tinyfish_fetches": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "updated_at": {
                    "type": "string"
                }
            }
        },
        "dto.RecommendationResult": {
            "type": "object",
            "properties": {
                "admission_likelihood_score": {
                    "type": "integer"
                },
                "improvements": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "rank_order": {
                    "type": "integer"
                },
                "reason": {
                    "type": "string"
                },
                "risks": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "student_fit_score": {
                    "type": "integer"
                },
                "tier": {
                    "type": "string"
                },
                "university_id": {
                    "type": "string"
                },
                "university_name": {
                    "type": "string"
                }
            }
        },
        "dto.ReportJobRequest": {
            "type": "object",
            "required": [
                "callback_url",
                "case_id",
                "job_id"
            ],
            "properties": {
                "callback_url": {
                    "type": "string"
                },
                "case_id": {
                    "type": "string"
                },
                "job_id": {
                    "type": "string"
                },
                "recommendations": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/dto.RecommendationResult"
                    }
                },
                "student_name": {
                    "type": "string"
                }
            }
        },
        "dto.SearchAttempt": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string"
                },
                "query": {
                    "type": "string"
                },
                "result_count": {
                    "type": "integer"
                }
            }
        },
        "response.ErrorInfo": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string"
                },
                "details": {
                    "type": "string"
                },
                "message": {
                    "type": "string"
                }
            }
        },
        "response.Response": {
            "type": "object",
            "properties": {
                "data": {},
                "error": {
                    "$ref": "#/definitions/response.ErrorInfo"
                },
                "success": {
                    "type": "boolean"
                }
            }
        }
    }
}