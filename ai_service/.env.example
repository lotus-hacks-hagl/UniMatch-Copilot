# AI Service Environment Configuration
# Copy this file to .env and fill in the values

# Server Configuration
PORT=9000
LOG_LEVEL=INFO

# Job Database (PostgreSQL)
# Format: postgresql://user:password@host:port/dbname
JOB_DATABASE_URL=postgresql://postgres:password@db:5432/unimatch_jobs

# Anthropic / Claude Configuration
# Set ANTHROPIC_API_KEY for direct usage, or ANTHROPIC_BASE_URL if using a proxy
ANTHROPIC_API_KEY=
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_BASE_URL=

# Search & Research APIs
# Get your keys at https://exa.ai/ and https://www.agentql.com/
EXA_API_KEY=
AGENTQL_API_KEY=

# Knowledge Graph (Neo4j)
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_MCP_URL=http://neo4j-mcp:8081/api/mcp/

# TinyFish (Optional - for advanced crawling)
TINYFISH_API_KEY=
